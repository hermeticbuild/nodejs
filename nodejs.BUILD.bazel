    outs = [
        "generated/node_inspector/src/node/inspector/protocol/DOMStorage.cpp",
        "generated/node_inspector/src/node/inspector/protocol/DOMStorage.h",
        "generated/node_inspector/src/node/inspector/protocol/Forward.h",
        "generated/node_inspector/src/node/inspector/protocol/IO.cpp",
        "generated/node_inspector/src/node/inspector/protocol/IO.h",
        "generated/node_inspector/src/node/inspector/protocol/Network.cpp",
        "generated/node_inspector/src/node/inspector/protocol/Network.h",
        "generated/node_inspector/src/node/inspector/protocol/NodeRuntime.cpp",
        "generated/node_inspector/src/node/inspector/protocol/NodeRuntime.h",
        "generated/node_inspector/src/node/inspector/protocol/NodeTracing.cpp",
