        "generated/node_inspector/src/node/inspector/protocol/Protocol.h",
        "generated/node_inspector/src/node/inspector/protocol/Runtime.h",
        "generated/node_inspector/src/node/inspector/protocol/Storage.cpp",
        "generated/node_inspector/src/node/inspector/protocol/Storage.h",
        "generated/node_inspector/src/node/inspector/protocol/Target.cpp",
        "generated/node_inspector/src/node/inspector/protocol/Target.h",
    ],
    cmd = "$(execpath :inspector_code_generator) --inspector_protocol_dir deps/inspector_protocol --jinja_dir . --output_base $(RULEDIR)/generated/node_inspector/src --config $(location src/inspector/node_protocol_config.json)",
