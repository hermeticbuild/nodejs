py_binary(
    name = "libffi_generate_headers",
    srcs = ["deps/libffi/generate-headers.py"],
    data = [
        "deps/libffi/include/ffi.h.in",
        "deps/libffi/src/aarch64/ffitarget.h",
        "deps/libffi/src/arm/ffitarget.h",
        "deps/libffi/src/loongarch64/ffitarget.h",
        "deps/libffi/src/mips/ffitarget.h",
        "deps/libffi/src/powerpc/ffitarget.h",
        "deps/libffi/src/riscv/ffitarget.h",
        "deps/libffi/src/x86/ffitarget.h",
    ],
    main = "deps/libffi/generate-headers.py",
)

genrule(
    name = "libffi_headers_linux_arm64",
    outs = [
        "generated/libffi/linux_arm64/ffi.h",
        "generated/libffi/linux_arm64/fficonfig.h",
        "generated/libffi/linux_arm64/ffitarget.h",
    ],
    cmd = "$(execpath :libffi_generate_headers) --output-dir $(RULEDIR)/generated/libffi/linux_arm64 --target-arch arm64 --os linux",
    tools = [":libffi_generate_headers"],
)

genrule(
    name = "libffi_headers_linux_x86_64",
    outs = [
        "generated/libffi/linux_x86_64/ffi.h",
