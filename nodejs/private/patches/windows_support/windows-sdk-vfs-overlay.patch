+def _write_vfs_overlay(repository_ctx, sysroot_dir, include_version):
+    roots = []
+    for include_root in [
+        "{}/base/c/Include/{}/ucrt".format(sysroot_dir, include_version),
+        "{}/base/c/Include/{}/shared".format(sysroot_dir, include_version),
+        "{}/base/c/Include/{}/um".format(sysroot_dir, include_version),
+        "{}/base/c/Include/{}/winrt".format(sysroot_dir, include_version),
+    ]:
+        files = []
+        _collect_files_recursive(repository_ctx.path(include_root), files)
+        for src_rel in sorted([_relative_to_repo_root(repository_ctx, f) for f in files]):
+            roots.append({
+                "external-contents": src_rel,
+                "name": src_rel,
+                "type": "file",
+            })
+
+    repository_ctx.file(
+        _VFS_OVERLAY,
+        json.encode({
+            "case-sensitive": False,
+            "overlay-relative": True,
+            "root-relative": "overlay-dir",
+            "roots": roots,
+            "use-external-names": False,
+            "version": 0,
+        }),
+    )
