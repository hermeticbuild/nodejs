+def _write_lowercase_library_aliases(repository_ctx, sysroot_dir, architectures):
+    seen_architectures = {}
+    for arch in architectures:
+        if seen_architectures.get(arch, False):
+            continue
+        seen_architectures[arch] = True
+
+        for library_kind in ["ucrt", "um"]:
+            source_dir = "{}/{}/c/{}/{}".format(sysroot_dir, arch, library_kind, arch)
+            files = []
+            _collect_files_recursive(repository_ctx.path(source_dir), files)
+            for src_rel in sorted([_relative_to_repo_root(repository_ctx, f) for f in files]):
+                if not src_rel.lower().endswith(".lib"):
+                    continue
+                dst_rel = "{}/{}/c/{}/{}/{}".format(_LOWERCASE_SYSROOT_DIR, arch, library_kind, arch, _basename(src_rel).lower())
+                repository_ctx.symlink(src_rel, dst_rel)
+
